# Variables pour le build Android (atelier Capacitor)
# Copiez vers .env à la racine ou exportez avant ./scripts/build-android.sh

APP_NAME=CareerAI
APP_ID=live.careerai.app
NODE_VERSION=20
ANDROID_SDK_VERSION=34

# L'app mobile charge le site en production (API Next.js + Supabase)
CAPACITOR_REMOTE_URL=https://www.careerai.live

# true = export statique Next (échoue si API routes / SSR — atelier pur uniquement)
CAPACITOR_STATIC_EXPORT=false
